{
  "scripts": {
    "js:visualize": "yarn prod:build:js -- --metafile=js_bundle_metadata.json && esbuild-visualizer --metadata=js_bundle_metadata.json --filename=js_bundle_stats.html",
    "build": "yarn build:js && yarn build:css",
    "build:js": "esbuild app/javascript/*.js --bundle --sourcemap --outdir=app/assets/builds/avo-rhino_field",
    "build:css": "tailwindcss -i app/assets/stylesheets/avo-rhino_field/application.css -o app/assets/builds/avo-rhino_field/application.css --minify",
    "prod:build": "yarn prod:build:js && yarn prod:build:css",
    "prod:build:js": "esbuild app/javascript/*.js --bundle --sourcemap --minify --outdir=app/assets/builds/avo-rhino_field",
    "prod:build:css": "yarn build:css"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@tiptap/extension-color": "^2.6.5",
    "@tiptap/extension-text-style": "^2.6.5",
    "@tailwindcss/cli": "^4.1.11",
    "rhino-editor": "^0.16.8",
    "tailwindcss": "^4.1.11"
  },
  "name": "avo-rhino_field",
  "version": "0.0.15",
  "main": "index.js",
  "repository": "https://github.com/avo-hq/avo-rhino_field",
  "author": "Adrian Marin <adrian@adrianthedev.com>",
  "license": "Commercial",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.23.1",
    "esbuild-visualizer": "^0.3.1"
  }
}
